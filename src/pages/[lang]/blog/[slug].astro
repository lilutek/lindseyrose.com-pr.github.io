---
import Base from '../../../layouts/Base.astro';
import { useTranslations } from '../../../i18n/index';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(p => ({
    params: { lang: p.data.lang, slug: p.slug.replace(/^(en|es)\//, '') },
    props: { post: p },
  }));
}

const { lang } = Astro.params;
const { post } = Astro.props;
const t = useTranslations(lang);
const { Content } = await post.render();
---

<Base title={post.data.title} description={post.data.description} lang={lang}>
  <article class="blog-post-container">
    <div class="post-hero">
      <div class="post-hero-glow" aria-hidden="true"></div>
      <div class="container">
        <div class="post-meta reveal">
          <a href={`/${lang}/blog`} class="back-link">← {t.nav.blog}</a>
          {post.data.tags.map(tag => <span class="card-tag">{tag}</span>)}
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString(lang === 'en' ? 'en-US' : 'es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
        <h1 class="reveal">{post.data.title}</h1>
        <p class="lead reveal">{post.data.description}</p>
      </div>
    </div>
    {post.data.image && (
      <div class="post-cover reveal">
        <div class="container">
          <img src={post.data.image} alt={post.data.title} width="1200" height="500" loading="eager" />
        </div>
      </div>
    )}
    <div class="container">
      <div class="prose reveal">
        <Content />
      </div>
    </div>
  </article>
</Base>

<style>
  .post-hero { position: relative; padding-block: var(--space-xl); overflow: hidden; }
  .post-hero-glow { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(187, 134, 252, 0.08), transparent 70%); pointer-events: none; }
  .post-meta { display: flex; align-items: center; flex-wrap: wrap; gap: var(--space-xs); margin-bottom: var(--space-sm); }
  .back-link { font-family: var(--font-heading); font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); text-decoration: none; transition: color var(--transition); margin-right: var(--space-xs); }
  .back-link:hover { color: var(--accent); }
  .post-meta time { font-size: 0.8rem; color: var(--text-secondary); margin-left: auto; }
  .lead { font-size: 1.1rem; }
  .post-cover { margin-block: var(--space-lg); }
  .post-cover img { width: 100%; height: 400px; object-fit: cover; border-radius: var(--radius-lg); border: 1px solid var(--border); }

  .prose {
    max-width: 72ch;
    margin-inline: auto;
    padding-block: var(--space-lg) var(--space-2xl);
  }
  .prose :global(h2) { font-size: 1.8rem; margin-top: var(--space-lg); margin-bottom: var(--space-sm); }
  .prose :global(h3) { font-size: 1.3rem; margin-top: var(--space-md); margin-bottom: 0.5rem; }
  .prose :global(p) { color: var(--text-secondary); margin-bottom: var(--space-sm); max-width: unset; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; color: var(--text-secondary); margin-bottom: var(--space-sm); }
  .prose :global(li) { margin-bottom: 0.4rem; }
  .prose :global(strong) { color: var(--text-primary); }
  .prose :global(a) { color: var(--accent); }
  .prose :global(blockquote) { border-left: 3px solid var(--accent); padding-left: var(--space-sm); color: var(--text-secondary); font-style: italic; margin-block: var(--space-md); }
  .prose :global(code) { background: var(--surface); padding: 0.2em 0.4em; border-radius: 4px; font-size: 0.9em; }
</style>
